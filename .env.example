# Copy this to .env.local and fill in real values.
# .env.local is gitignored; this .env.example IS committed.

NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# devnet | mainnet-beta. Devnet has safe defaults; mainnet must be explicit.
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SERVER_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_VELORAN_PROGRAM_ID=2CtnLfdePpjitQQLtHrQAsa74RXLiubKfSdJmjy2pGcS
# Public treasury address, not a private key. Keep VELORAN_TREASURY too for server clarity.
NEXT_PUBLIC_VELORAN_TREASURY=DgGYE7boZTEwrotFsYS9bFYsrgpz8TC76cXCZ8GcFKnP
VELORAN_TREASURY=DgGYE7boZTEwrotFsYS9bFYsrgpz8TC76cXCZ8GcFKnP

SESSION_SECRET=

# Production uses Postgres. Local SQLite is no longer valid with provider=postgresql.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/veloran?schema=public"

ANTHROPIC_API_KEY=
